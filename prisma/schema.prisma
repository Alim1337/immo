  Demande_client_valide Demande_client_valide[]
  Demande_client_vip_   Demande_client_vip_[]
  Proprietaire          Proprietaire[]
  Rdv                   Rdv[]
  biens_loue            biens_loue[]
  likes                 likes[]
  message               message[]
  negotiation           negotiation[]
  negotiation_demande   negotiation_demande[]
}

model Client_vip {
