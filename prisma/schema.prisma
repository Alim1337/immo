// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  CLIENT
  PROPRIETAIRE
  AGENCE
}

enum TypeBien {
  APPARTEMENT
  VILLA
  MAISON
  BUREAU
  LOCAL_COMMERCIAL
  TERRAIN
  STUDIO
}

enum TypeTransaction {
  LOCATION
  VENTE
  LOCATION_VACANCES
}

enum EtatBien {
  DISPONIBLE
  RESERVE
  LOUE
  VENDU
  SUSPENDU
}

enum StatutNegotiation {
  EN_COURS
  ACCEPTEE
  REFUSEE
  ANNULEE
  FINALISEE
}

enum StatutDemande {
  EN_ATTENTE
  EN_COURS
  SATISFAITE
  EXPIREE
  ANNULEE
}

enum StatutRdv {
  CONFIRME
  ANNULE
  EFFECTUE
}

enum TypeNotification {
  NOUVELLE_NEGOCIATION
  MESSAGE_RECU
  RDV_CONFIRME
  DEMANDE_INTERESSANTE
  BIEN_MODIFIE
  COMPTE_VERIFIE
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id               Int       @id @default(autoincrement())
  nom              String
  prenom           String?
  raison_sociale   String?   // nom de l'agence si role=AGENCE
  email            String    @unique
  telephone        String    @unique
  mot_de_passe     String
  date_naissance   DateTime?
  sexe             String?
  avatar_url       String?
  ville            String?
  wilaya           String?
  date_inscription DateTime  @default(now())
  role             Role      @default(CLIENT)
  est_verifie      Boolean   @default(false)
  est_actif        Boolean   @default(true)

  // Relations
  biens                  Bien[]
  demandes               Demande[]
  negotiations_client    Negotiation[]  @relation("neg_client")
  negotiations_proprio   Negotiation[]  @relation("neg_proprio")
  messages               Message[]
  avis_donnes            Avis[]         @relation("auteur_avis")
  avis_recus             Avis[]         @relation("cible_avis")
  favoris                Favori[]
  notifications          Notification[]
  rdvs_client            Rdv[]          @relation("rdv_client")
  rdvs_proprio           Rdv[]          @relation("rdv_proprio")
  interets               Interet[]
}

model Bien {
  id               Int             @id @default(autoincrement())
  titre            String
  description      String?
  type_bien        TypeBien
  type_transaction TypeTransaction
  adresse          String?
  ville            String
  wilaya           String
  code_postal      String?
  superficie       Decimal?
  nbr_chambres     Int?
  nbr_salles_bain  Int?
  nbr_etages       Int?
  prix             Decimal
  etat             EtatBien        @default(DISPONIBLE)
  est_meuble       Boolean         @default(false)
  images           String[]        // Cloudinary URLs
  equipements      String[]        // ["wifi","parking","piscine"]
  date_publication DateTime        @default(now())
  date_mise_a_jour DateTime        @updatedAt
  proprietaire_id  Int

  proprietaire     User            @relation(fields: [proprietaire_id], references: [id])
  negotiations     Negotiation[]
  favoris          Favori[]
  avis             Avis[]
  visites          Visite[]
}

model Negotiation {
  id               Int               @id @default(autoincrement())
  client_id        Int
  proprietaire_id  Int
  bien_id          Int
  prix_propose     Decimal
  statut           StatutNegotiation @default(EN_COURS)
  commentaire      String?
  duree_proposee   String?
  date_creation    DateTime          @default(now())
  date_mise_a_jour DateTime          @updatedAt

  client           User              @relation("neg_client",  fields: [client_id],       references: [id])
  proprietaire     User              @relation("neg_proprio", fields: [proprietaire_id], references: [id])
  bien             Bien              @relation(fields: [bien_id], references: [id])
  messages         Message[]
  rdvs             Rdv[]
}

model Message {
  id             Int         @id @default(autoincrement())
  negotiation_id Int
  expediteur_id  Int
  contenu        String
  lu             Boolean     @default(false)
  date_envoi     DateTime    @default(now())

  negotiation    Negotiation @relation(fields: [negotiation_id], references: [id], onDelete: Cascade)
  expediteur     User        @relation(fields: [expediteur_id], references: [id])
}

model Demande {
  id               Int             @id @default(autoincrement())
  client_id        Int
  type_bien        TypeBien?
  type_transaction TypeTransaction?
  prix_min         Decimal?
  prix_max         Decimal?
  superficie_min   Decimal?
  nbr_chambres_min Int?
  ville            String?
  wilaya           String?
  description      String?
  statut           StatutDemande   @default(EN_ATTENTE)
  date_creation    DateTime        @default(now())
  date_expiration  DateTime?

  client           User            @relation(fields: [client_id], references: [id])
  interets         Interet[]
}

model Interet {
  id              Int      @id @default(autoincrement())
  demande_id      Int
  proprietaire_id Int
  date            DateTime @default(now())

  demande         Demande  @relation(fields: [demande_id],      references: [id])
  proprietaire    User     @relation(fields: [proprietaire_id], references: [id])

  @@unique([demande_id, proprietaire_id])
}

model Rdv {
  id              Int          @id @default(autoincrement())
  negotiation_id  Int?
  client_id       Int
  proprietaire_id Int
  date_rdv        DateTime
  lieu            String?
  statut          StatutRdv    @default(CONFIRME)
  notes           String?

  negotiation     Negotiation? @relation(fields: [negotiation_id], references: [id])
  client          User         @relation("rdv_client",  fields: [client_id],       references: [id])
  proprietaire    User         @relation("rdv_proprio", fields: [proprietaire_id], references: [id])
}

model Avis {
  id          Int      @id @default(autoincrement())
  auteur_id   Int
  cible_id    Int
  bien_id     Int?
  note        Int      // 1–5
  commentaire String?
  date        DateTime @default(now())

  auteur      User     @relation("auteur_avis", fields: [auteur_id], references: [id])
  cible       User     @relation("cible_avis",  fields: [cible_id],  references: [id])
  bien        Bien?    @relation(fields: [bien_id], references: [id])
}

model Favori {
  id      Int      @id @default(autoincrement())
  user_id Int
  bien_id Int
  date    DateTime @default(now())

  user    User     @relation(fields: [user_id], references: [id])
  bien    Bien     @relation(fields: [bien_id], references: [id])

  @@unique([user_id, bien_id])
}

model Notification {
  id      Int              @id @default(autoincrement())
  user_id Int
  type    TypeNotification
  titre   String
  contenu String
  lue     Boolean          @default(false)
  lien    String?
  date    DateTime         @default(now())

  user    User             @relation(fields: [user_id], references: [id])
}

model Visite {
  id      Int      @id @default(autoincrement())
  bien_id Int
  date    DateTime @default(now())

  bien    Bien     @relation(fields: [bien_id], references: [id])
}
